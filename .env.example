# ---------------------------------------------------------------------------
# LevelUp Platform - environment variable template
# Copy this file to .env.local and fill in real values.
# .env.local and .env are both gitignored - never commit real secrets.
# ---------------------------------------------------------------------------

# OpenAI API Configuration
OPENAI_API_KEY=

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ALPHA_VANTAGE_API_KEY=
NEXT_PUBLIC_USE_REAL_ETH_DATA=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=
PLAID_PRODUCTS=
PLAID_COUNTRY_CODES=
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=

NEXT_PUBLIC_APP_URL=
CRON_SECRET=

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Comma-separated emails with full app access (bypass paywall for testing)
FULL_ACCESS_EMAILS=

# ---------------------------------------------------------------------------
# Storage architecture
#
# The codebase, git repo, node_modules/.venv, and the active Supabase
# connection always stay local - none of that is affected by the variables
# below.
#
# These variables only control where LARGE, GENERATED, or STATIC content
# lives: media assets, finished exports (shorts/blog images/ebooks), and
# timestamped database backups. By default they point into iCloud Drive so
# that content syncs across Macs without bloating the git repo. Override any
# of them to store that content somewhere else (external drive, another
# cloud-synced folder, etc). All are optional - sensible macOS defaults are
# used if unset. See README.md "Storage Architecture" for details.
# ---------------------------------------------------------------------------

# Root of all iCloud-synced LevelUp storage.
# Default: ~/Library/Mobile Documents/com~apple~CloudDocs/LevelUpSolutions
# LEVELUP_STORAGE_DIR=

# Large media: images, videos, audio, thumbnails, logos, characters.
# Default: $LEVELUP_STORAGE_DIR/assets
# LEVELUP_ASSETS_DIR=

# Finished output: shorts, blog images, ebook files.
# Default: $LEVELUP_STORAGE_DIR/exports
# LEVELUP_EXPORTS_DIR=

# Backups root (database backups + project snapshots).
# Default: $LEVELUP_STORAGE_DIR/backups
# LEVELUP_BACKUPS_DIR=

# Timestamped database dumps only - never the active dev database.
# Default: $LEVELUP_BACKUPS_DIR/database-backups
# LEVELUP_DATABASE_BACKUP_DIR=
